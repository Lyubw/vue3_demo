                    .map(smsQuota -> smsQuota.getUseQuota())
                    .mapToLong(Long::longValue).sum();


            Double itemThreshold = item.getThreshold();
            if (Objects.isNull(itemThreshold)) {
                return;
            }
            BigDecimal threshold = new BigDecimal(itemThreshold);
            // 计算是否超过预定的百分比
            BigDecimal inDividend = new BigDecimal(inUsable);
            BigDecimal inDivisor = new BigDecimal(Objects.equals(inInitial, 0L) ? 1 : inInitial);
            BigDecimal inQuotient = inDividend.divide(inDivisor, 3, RoundingMode.HALF_UP);

            BigDecimal outDividend = new BigDecimal(outUsable);
            BigDecimal outDivisor = new BigDecimal(Objects.equals(outInitial, 0L) ? 1 : outInitial);
            BigDecimal outQuotient = outDividend.divide(outDivisor, 3, RoundingMode.HALF_UP);

            if (inQuotient.compareTo(threshold) < 0
                    && outQuotient.compareTo(threshold) < 0) {
                return;
            }

            _userIds.add(Long.parseLong(item.getApplicant()));
            if (!(inQuotient.compareTo(threshold) < 0)) {

