    @Override
    public SmsClientQuotaUsableResp usableQuota(Long clientId) {

        // 过期时间 > 当前时间 有效可用额度
        // 过期时间 <= 当前时间 无效可用额度
//        List<SmsQuota> smsQuotas = smsQuotaMapper.selectList(Wrappers.<SmsQuota>lambdaQuery()
//                .eq(SmsQuota::getClientId, clientId)
//                .eq(SmsQuota::getStatus, StatusEnums.NORMAL.getCode())
//                .gt(SmsQuota::getExpireDate, new Date()));
//        List<SmsQuota> smsQuotas = smsQuotaMapper.selectList(Wrappers.<SmsQuota>lambdaQuery()
//                .eq(SmsQuota::getClientId, clientId)
//                .eq(SmsQuota::getStatus, StatusEnums.NORMAL.getCode()));
        List<SmsQuota> smsQuotas = smsQuotaMapper.selectList(Wrappers.<SmsQuota>lambdaQuery()
                .eq(SmsQuota::getClientId, clientId)
                .eq(SmsQuota::getStatus, StatusEnums.NORMAL.getCode()));
        //余量从redis中获取
        long inCount = 0L;
        long inUsable = 0L;

        long outCount = 0L;
        long outUsable = 0L;
        BigDecimal outTotalAmount = BigDecimal.ZERO;
        BigDecimal outRemainAmount = BigDecimal.ZERO;

        for(SmsQuota quota : smsQuotas){
            Long count = Optional.ofNullable(quota.getInitialQuota()).orElse(0L);
            Long useCount = Optional.ofNullable(quota.getUseQuota()).orElse(0L);
            String key = SmsConstants.SMS_CLIENT_QUOTA + ":" + quota.getQuotaId();
            long value = RedisUtil.getString(key)!=null?Long.parseLong(RedisUtil.getString(key)):(count - useCount);
            if(Objects.equals(quota.getCountryType(), CountryTypeEnums.IN.getCode())){
                inCount += count;
                inUsable += value;
            }else {
                outCount += count;
                outUsable += value;
                // 国际短信金额统计（使用BigDecimal计算）
                BigDecimal initialAmount = Optional.ofNullable(quota.getInitialAmount()).orElse(BigDecimal.ZERO);
                BigDecimal useAmount = Optional.ofNullable(quota.getUseAmount()).orElse(BigDecimal.ZERO);
                outTotalAmount = outTotalAmount.add(initialAmount);
                outRemainAmount = outRemainAmount.add(initialAmount.subtract(useAmount));
            }
        }

        // 国内短信累计
//        Long inUsable = smsQuotas.stream()
//                .filter(smsQuota
//                        -> smsQuota.getCountryType() == CountryTypeEnums.IN.getCode())
//                .map(smsQuota -> smsQuota.getInitialQuota() - smsQuota.getUseQuota())
//                .mapToLong(Long::longValue).sum();
//
//        // 国际短信累计
//        Long outUsable = smsQuotas.stream()
//                .filter(smsQuota
//                        -> smsQuota.getCountryType() == CountryTypeEnums.OUT.getCode())
//                .map(smsQuota -> smsQuota.getInitialQuota() - smsQuota.getUseQuota())
//                .mapToLong(Long::longValue).sum();

        SmsClientQuotaUsableResp rtn = new SmsClientQuotaUsableResp();
        rtn.setInCount(inCount);
        rtn.setInUsable(inUsable);
        rtn.setOutCount(outCount);
        rtn.setOutUsable(outUsable);
        rtn.setOutTotalAmount(setAmountScale(outTotalAmount));
        rtn.setOutRemainAmount(setAmountScale(outRemainAmount));
        return rtn;
    }

    @Override
    public void deleteQuota(Long quotaId) {

        SmsQuota quota = smsQuotaMapper.selectById(quotaId);
        Long clientId = quota.getClientId();

        int count = smsQuotaMapper.deleteById(quotaId);

        if (count == 0) {
            throw new GlobalException(TipsEnum.getTips(TipsEnum.DELETE_FAILED));
        }

        SmsClient smsClient = smsClientMapper.selectById(clientId);
        // 判断客户端状态 是否审批完成-审批完成才推送redis
        if (!Objects.equals(ClientStatusEnums.APPROVALED.getCode(), smsClient.getStatus())) {
            return;
        }
        // 更新redis
        pushClientInfo(smsClient, smsQuotaMapper, true, quota);
    }

