                        put("sms_type", CountryTypeEnums.getCountryTypeNameByCode(item.getType()));
                    }})
                    .build();

            // redis 设置值
            SmsRedisUtil.set(redisKey, true);
            SmsRedisUtil.expire(redisKey, DateUtil.getToDayLastTime());

            //发送邮件
            MailResponse send = MailClientUtil.send(clientParam);

            log.info("发送邮件结果:{}", send);
        });

        log.info("校验客户端额度预警结束。。。");
    }

    @Override
    public void quotaRecharge(SmsQuotaRechargeReq req) {
        //根据clientId查询额度
        SmsQuota smsQuota = smsQuotaMapper.selectOne(
                Wrappers.<SmsQuota>lambdaQuery()
                        .eq(SmsQuota::getClientId, req.getClientId())
                        .eq(SmsQuota::getCountryType, req.getCountryType())
                        .eq(SmsQuota::getStatus, StatusEnums.NORMAL.getCode()));
        if (smsQuota == null){
            throw new GlobalException("新增失败，额度id不存在");
        }
        Long quotaBefore = Optional.ofNullable(smsQuota.getInitialQuota())
                .orElse(0L);
        //新增额度充值记录
        SmsQuotaRecharge smsQuotaRecharge = new SmsQuotaRecharge();
        smsQuotaRecharge.setClientId(req.getClientId());
        smsQuotaRecharge.setQuotaRechargeId(IdUtil.getSnowflake().nextId());
        smsQuotaRecharge.setQuotaId(smsQuota.getQuotaId());
        smsQuotaRecharge.setQuotaBefore(quotaBefore);
        boolean isIn = req.getCountryType().equals(CountryTypeEnums.IN.getCode());
        //区分国内外短信充值方式
        if(isIn){
            if(req.getQuotaChange() == null){
                throw new GlobalException("新增失败，国内短信充值数量不能为空");
            }
            smsQuotaRecharge.setQuotaChange(req.getQuotaChange());
            smsQuotaRecharge.setQuotaAfter(quotaBefore+req.getQuotaChange());
        }else{
            //国外短信，记录充值金额，根据服务商单价计算充值条数
            if(req.getRechargeAmount() == null){
                throw new GlobalException("新增失败，国际短信充值金额不能为空");
            }
            BigDecimal rechargeAmount = setAmountScale(req.getRechargeAmount());
            smsQuotaRecharge.setRechargeAmount(rechargeAmount);
            //根据客户端拿到国外服务商的参数
            Long clientId = smsQuota.getClientId();
            //获取国外服务商单价
            Long outId = smsClientMapper.selectById(clientId).getOutServerId();
            if(outId == null){
                throw new GlobalException("新增失败，请先配置国外服务商");
            }
            BigDecimal unitPrice = getUnitPriceFromServer(outId);
            if(unitPrice == null || unitPrice.compareTo(BigDecimal.ZERO) <= 0){
                throw new GlobalException("新增失败，服务商单价配置无效");
            }
            smsQuotaRecharge.setUnitPrice(unitPrice);
            // 计算充值条数：充值金额 / 单价（向下取整）
            BigDecimal quotaChangeDecimal = rechargeAmount.divide(unitPrice, 0, RoundingMode.DOWN);
            Long quotaChange = quotaChangeDecimal.longValue();
            if (quotaChange <= 0) {
                throw new GlobalException("充值金额不足以兑换1条短信");
            }
            smsQuotaRecharge.setQuotaChange(quotaChange);
            smsQuotaRecharge.setQuotaAfter(quotaBefore + quotaChange);
        }
        smsQuotaRecharge.setCountryType(req.getCountryType());
        smsQuotaRecharge.setStatus(StatusEnums.DISABLE.getCode());
        smsQuotaRecharge.setRemark(req.getRemark());
        smsQuotaRecharge.setCreateTime(new Date());
        smsQuotaRecharge.setCreateUser(UserThreadLocal.getUserId().toString());
        smsQuotaRechargeMapper.insert(smsQuotaRecharge);
    }

    /**
     * 金额精度控制：保留5位小数
     */
    private static final int AMOUNT_SCALE = 5;
    private static final RoundingMode AMOUNT_ROUNDING_MODE = RoundingMode.HALF_UP;

    /**
     * 设置金额精度（保留5位小数）
     */
    private BigDecimal setAmountScale(BigDecimal amount) {
        if (amount == null) {
            return BigDecimal.ZERO;
        }
        return amount.setScale(AMOUNT_SCALE, AMOUNT_ROUNDING_MODE);
    }

    /**
     * 国际短信从服务商配置获取单价（返回BigDecimal，精度5位小数）
     */
    private BigDecimal getUnitPriceFromServer(Long serverId) {
        if (serverId == null) {
            return null;
        }
        SmsServer server = smsServerMapper.selectById(serverId);
        if (server == null || StrUtil.isEmpty(server.getServerParams())) {
            return null;
        }
        List<ServerParams> params = JSON.parseArray(server.getServerParams(), ServerParams.class);
        for (ServerParams param : params) {
            if ("unitPrice".equals(param.getKey()) && StrUtil.isNotEmpty(param.getValue())) {
                try {
                    BigDecimal unitPrice = new BigDecimal(param.getValue());
                    return setAmountScale(unitPrice);
                } catch (NumberFormatException e) {
                    log.error("解析单价失败: {}", param.getValue(), e);
                    return null;
                }
            }
        }
        return null;
    }

    @Override
    @Transactional
    public void enableRecharge(Long quotaRechargeId){
        SmsQuotaRecharge smsQuotaRecharge = smsQuotaRechargeMapper.selectById(quotaRechargeId);
        if (smsQuotaRecharge == null){
            throw new GlobalException("启用失败，充值记录不存在");
        }
        if (smsQuotaRecharge.getStatus().equals(StatusEnums.NORMAL.getCode())){
            throw new GlobalException("启用失败，充值记录已启用");
        }
        smsQuotaRecharge.setStatus(StatusEnums.NORMAL.getCode());

        //把数量加到额度上
        SmsQuota smsQuota = smsQuotaMapper.selectById(smsQuotaRecharge.getQuotaId());
        if (smsQuota == null) {
            throw new GlobalException("启用失败，关联的额度记录不存在");
        }
        Long initial = Optional.ofNullable(smsQuota.getInitialQuota())
                .orElse(0L);
        Long new_quota = initial + smsQuotaRecharge.getQuotaChange();
        smsQuota.setInitialQuota(new_quota);

        //国际短信更新充值金额
        if(Objects.equals(smsQuota.getCountryType(), CountryTypeEnums.OUT.getCode())){
            BigDecimal initAmountBefore = Optional.ofNullable(smsQuota.getInitialAmount())
                    .orElse(BigDecimal.ZERO);
            BigDecimal rechargeAmount = Optional.ofNullable(smsQuotaRecharge.getRechargeAmount())
                    .orElse(BigDecimal.ZERO);
            BigDecimal newInitialAmount = initAmountBefore.add(rechargeAmount);
            smsQuota.setInitialAmount(setAmountScale(newInitialAmount));
            // 已使用金额保持不变
            BigDecimal useAmount = Optional.ofNullable(smsQuota.getUseAmount())
                    .orElse(BigDecimal.ZERO);
            smsQuota.setUseAmount(setAmountScale(useAmount));
        }
        smsQuotaMapper.updateById(smsQuota);

        //刷一下充值前和充值后的额度，取数据库最新的值
        smsQuotaRecharge.setQuotaBefore(new_quota-smsQuotaRecharge.getQuotaChange());
        smsQuotaRecharge.setQuotaAfter(new_quota);
        smsQuotaRecharge.setUpdateTime(new Date());
        smsQuotaRecharge.setUpdateUser(UserThreadLocal.getUserId().toString());
        smsQuotaRechargeMapper.updateById(smsQuotaRecharge);

        enableQuotaPushRedis(smsQuota, smsQuotaRecharge, initial, new_quota);

    }

    private void enableQuotaPushRedis(SmsQuota smsQuota, SmsQuotaRecharge smsQuotaRecharge, Long initial, Long new_quota) {
        //通知redis客户端额度更新-key为客户端id，需要区分是审批前还是审批后，状态是未审批不推redis,已审批状态下再推
        executor.execute(() -> {
            SmsClient smsClient = smsClientMapper.selectById(smsQuota.getClientId());
            if(Objects.equals(smsClient.getStatus(), ClientStatusEnums.APPROVALED.getCode())){
                //更新redis额度
                String key = SmsConstants.SMS_CLIENT_QUOTA + ":" + smsQuota.getQuotaId();
                if(RedisUtil.hasKey(key)){
                    RedisUtil.incr(key, smsQuotaRecharge.getQuotaChange());
                }else{
                    //redis不存在这个key
                    //首次充值则数量为change,非首次充值可能是由于redis key丢失，数量取数据库差值
                    Long _quota = initial > 0 ? new_quota - smsQuota.getUseQuota() : smsQuotaRecharge.getQuotaChange();
                    SmsRedisUtil.initQuotaPut(key, _quota);
                    log.info("首次启用充值额度，初始化短信额度到Redis, quotaId={}, available={}",
                            smsQuota.getQuotaId(), initial + smsQuotaRecharge.getQuotaChange());
                }
            }
        });
    }

    @Override
    public void cancelRecharge(Long quotaRechargeId){
        SmsQuotaRecharge smsQuotaRecharge = smsQuotaRechargeMapper.selectById(quotaRechargeId);
        if (smsQuotaRecharge == null){
            throw new GlobalException("删除失败，充值记录不存在");
        }
        if (smsQuotaRecharge.getStatus().equals(StatusEnums.NORMAL.getCode())){
            throw new GlobalException("删除失败，充值记录已启用");
        }
        smsQuotaRechargeMapper.deleteById(quotaRechargeId);
    }

