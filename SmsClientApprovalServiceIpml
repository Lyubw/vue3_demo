                clientMailSendParams.setUsePercentage(outQuotient.doubleValue() * 100 + "%");
                clientMailSendParams.setInitialSumQuota(outInitial);
                clientMailSendParams.setUseSumQuota(outUsable);
                clientMailSendParams.setType(CountryTypeEnums.OUT.getCode());
                clientMailSendParams.setUserId(item.getApplicant());
                _sendItems.add(clientMailSendParams);
            }
        });

        // 发送邮件提醒
        if (CollectionUtil.isEmpty(_sendItems)) {
            log.info("未发现预警额度，校验客户端额度预警结束。。。");
            return;
        }
        UserInfoQryReq userInfoQryReq = new UserInfoQryReq();
        userInfoQryReq.setUserIdList(_userIds);
        String result = adminFeign.queryUserInfoByUserIdOrNumber(userInfoQryReq);
        JSONObject jsonObject = JSONObject.parseObject(result);
        JSONArray resultData = jsonObject.getJSONArray(Constant.RESULT_DATA);
        List<UserInfoQryResp> respList =
                JSON.parseArray(resultData.toString(), UserInfoQryResp.class);

        Map<Long, UserInfoQryResp> userInfoMap = respList.stream()
                .collect(Collectors.toMap(UserInfoQryResp::getUserId, Function.identity()));

        _sendItems.forEach(item -> {
            String redisKey = Constant.SMS_QUOTA_WARNING_REDIS + ":"
                    + item.getClientCode() + ":" + item.getType();
            // 校验当前客户端预警是否已经发送邮件
            if (SmsRedisUtil.isExist(redisKey)) {
                return;
            }
            ClientParam clientParam = MailParamsBuilder.chain()
                    .receiver(userInfoMap.get(Long.parseLong(item.getUserId())).getUserEmail())
                    .templateKey(templateKey)
                    .templateParams(new HashMap<String, Object>() {{
                        put("user_name", userInfoMap.get(Long.parseLong(item.getUserId())).getUserZhName());
                        put("warning_value", item.getWarningPercentage());
