    @Override
    public void addQuota(SmsQuotaAddReq smsQuotaAddReq) {

        SmsQuota smsQuota = smsQuotaAddReq.entity();
        // 判断过期时间
//        if (!DateUtil.isAfter(smsQuotaAddReq.getExpireDate(), new Date())) {
//            smsQuota.setStatus(StatusEnums.DISABLE.getCode());
//        } else {
//            smsQuota.setStatus(StatusEnums.NORMAL.getCode());
//        }
        smsQuota.setStatus(StatusEnums.NORMAL.getCode());
        smsQuotaMapper.insert(smsQuota);

        SmsClient smsClient = smsClientMapper.selectById(smsQuota.getClientId());

        // 禁用状态不可推送 判断客户端状态 是否审批完成-审批完成才推送redis
        if (Objects.equals(StatusEnums.DISABLE.getCode(), smsQuota.getStatus()) ||
                !Objects.equals(ClientStatusEnums.APPROVALED.getCode(), smsClient.getStatus())) {
            return;
        }
        // 更新redis
        pushClientInfo(smsClient, smsQuotaMapper, false, smsQuotaMapper.selectById(smsQuota.getQuotaId()));

    }

    @Override
    public void updateQuota(SmsQuotaUpdateReq smsQuotaUpdateReq) {
        SmsQuota smsQuota = smsQuotaUpdateReq.entity();
        SmsQuota item = smsQuotaMapper.selectById(smsQuota.getQuotaId());
        if (item.getUseQuota() > smsQuota.getInitialQuota()) {
            throw new GlobalException(TipsEnum.getTips(TipsEnum.INITIAL_QUOTA_NOTUNDER_USE_QUOTA));
        }

        // 判断过期时间
