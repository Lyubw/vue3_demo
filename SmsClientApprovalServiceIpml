                clientMailSendParams.setClientName(item.getSystemName());
                clientMailSendParams.setAppName(item.getAppName());
                clientMailSendParams.setSmsProvider(SmsServerEnums.getNameByCode(item.getInServerCode()));
                clientMailSendParams.setWarningPercentage(threshold.doubleValue() * 100 + "%");
