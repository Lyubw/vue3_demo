    @Override
    public PageResult<SmsClientApprovalPageResp> paginQuery(SmsClientApprovalPageReq pageReq) {

        // 审批中、已生效、未通过
        List<Integer> statusList = new ArrayList<>();
        statusList.add(ClientStatusEnums.IN_APPROVALED.getCode());
        statusList.add(ClientStatusEnums.APPROVALED.getCode());
        statusList.add(ClientStatusEnums.NOT_APPROVALED.getCode());

        Page<SmsClient> pageServer = smsClientMapper.selectPage(new Page<>(pageReq.getPageNumber(), pageReq.getPageSize()),
                Wrappers.<SmsClient>lambdaQuery()
                        .in(SmsClient::getStatus, statusList)
                        .eq(!Objects.isNull(pageReq.getClientId()), SmsClient::getClientId, pageReq.getClientId())
                        .like(StringUtils.isNotEmpty(pageReq.getClientCode()),
                                SmsClient::getClientCode, pageReq.getClientCode())
                        .eq(StringUtils.isNotEmpty(pageReq.getAppCode()),
                                SmsClient::getAppCode, pageReq.getAppCode())
                        // 当状态传-1时 为查询全部数据
                        .eq(pageReq.getStatus() != -1, SmsClient::getStatus, pageReq.getStatus())
                        .orderByDesc(SmsClient::getCreateTime));

        return PageUtils.toPageResult(pageServer, SmsClientApprovalPageResp::vo);
    }

    @Override
    public void saveAndPass(SmsClientApprovalSaveAndPassReq req) {
        SmsClient smsClient = req.entity();
        Long clientId = smsClient.getClientId();
        // 根据当前客户端状态判断是否需要审批
        SmsClient entity = smsClientMapper.selectById(clientId);
        entity.setInServerCode(smsClient.getInServerCode());
        entity.setInServerId(smsClient.getInServerId());
        entity.setOutServerCode(smsClient.getOutServerCode());
        entity.setOutServerId(smsClient.getOutServerId());

        Integer status = entity.getStatus();
        if (Objects.equals(ClientStatusEnums.IN_APPROVALED.getCode(), status)) {
            // 待审核需要走审批
            smsClient.setStatus(ClientStatusEnums.APPROVALED.getCode());
            smsClient.setReviewer(UserThreadLocal.getUserId().toString());
            smsClient.setReviewerDate(new Date());

            smsClientMapper.updateById(smsClient);
            // 审批后自动创建两条额度表数据，一条国内额度，一条国外额度
            List<SmsQuota> quotaList = createQuotaPair(smsClient);
            smsQuotaMapper.insertBatch(quotaList);

            // 推送客户端信息到redis
            SmsClientInfo smsClientInfo =
                    SmsClientApprovalServiceIpml.convertInfo(entity, smsQuotaMapper);

            executor.execute(() -> {
                SmsRedisUtil.sendRedisQueue(clientTopic, smsClientInfo);
                SmsRedisUtil.addPut(SmsConstants.SMS_CLIENT, SmsClientInfo.class, smsClientInfo);
                // 审批通过需要推送额度信息
                // 20250422 第一次应该是当前客户端可用额度都推送 新增
                firstPushQuota(smsClientInfo);
            });

        } else {
            throw new GlobalException(TipsEnum.getTips(TipsEnum.STATUS_NOOPERATE));
        }
    }

    private static List<SmsQuota> createQuotaPair(SmsClient smsClient) {
        List<SmsQuota> quotaList = new ArrayList<>();

        SmsQuota smsQuotaIn = new SmsQuota();
        smsQuotaIn.setQuotaId(IdUtil.getSnowflakeNextId());
        smsQuotaIn.setClientId(smsClient.getClientId());
        smsQuotaIn.setCountryType(CountryTypeEnums.IN.getCode());
        smsQuotaIn.setStatus(StatusEnums.NORMAL.getCode());
        smsQuotaIn.setInitialQuota(0L);
        smsQuotaIn.setUseQuota(0L);
        smsQuotaIn.setCreateTime(new Date());
        smsQuotaIn.setCreateUser(UserThreadLocal.getUserId().toString());

        SmsQuota smsQuotaOut = new SmsQuota();
        smsQuotaOut.setQuotaId(IdUtil.getSnowflakeNextId());
        smsQuotaOut.setClientId(smsClient.getClientId());
        smsQuotaOut.setCountryType(CountryTypeEnums.OUT.getCode());
        smsQuotaOut.setStatus(StatusEnums.NORMAL.getCode());
        smsQuotaOut.setInitialQuota(0L);
        smsQuotaOut.setUseQuota(0L);
        smsQuotaOut.setInitialAmount(BigDecimal.ZERO);
        smsQuotaOut.setUseAmount(BigDecimal.ZERO);
        smsQuotaOut.setCreateTime(new Date());
        smsQuotaOut.setCreateUser(UserThreadLocal.getUserId().toString());

        quotaList.add(smsQuotaIn);
        quotaList.add(smsQuotaOut);
        return quotaList;
    }

    @Override
    public void save(SmsClientApprovalSaveAndPassReq req) {
        Long clientId = req.getClientId();
        SmsClient smsClient = smsClientMapper.selectById(clientId);

        // 判断状态
        if (!(ClientStatusEnums.APPROVALED.getCode().equals(smsClient.getStatus()))) {
            throw new GlobalException(TipsEnum.getTips(TipsEnum.STATUS_NOOPERATE));
        }

        // 记录模板被至为待编辑状态ID
        List<SmsTemplate> smsTemplateList = new ArrayList<>();

        // 判断短信服务是否变更
        Long oldInServerId = smsClient.getInServerId();
        Long oldOutServerId = smsClient.getOutServerId();
        Long inServerId = req.getInServerId();
        Long outServerId = req.getOutServerId();
        LambdaUpdateWrapper<SmsTemplate> inUpdateWrapper = null;
        LambdaUpdateWrapper<SmsTemplate> outUpdateWrapper = null;
        List<Long> inTemplateIds = new ArrayList<>();
        List<Long> outTemplateIds = new ArrayList<>();
        if (Objects.isNull(inServerId)
                || !inServerId.equals(oldInServerId)) {
            // 国内发生变更 -- 将对应的国内模板至为无效状态，需重新审核
            smsTemplateList =
                    smsTemplateService.list(Wrappers.<SmsTemplate>lambdaQuery()
                            .eq(SmsTemplate::getClientId, clientId)
                            .eq(SmsTemplate::getCountryType, CountryTypeEnums.IN.getCode()));
            inTemplateIds = smsTemplateList.stream().map(smsTemplate -> {
                return smsTemplate.getTemplateId();
            }).collect(Collectors.toList());

            inUpdateWrapper = new LambdaUpdateWrapper<>();
            inUpdateWrapper.set(SmsTemplate::getStatus, TemplateStatusEnums.WAIT_APPROVALED.getCode());
            inUpdateWrapper.set(SmsTemplate::getSignId, null);
            inUpdateWrapper.set(SmsTemplate::getSignName, null);
            inUpdateWrapper.set(SmsTemplate::getTemplateConvertContent, null);
            inUpdateWrapper.set(SmsTemplate::getServerTemplateId, null);
            if (Objects.isNull(inServerId)) {
                inUpdateWrapper.set(SmsTemplate::getClientId, null);
            }
            inUpdateWrapper.set(SmsTemplate::getServerId, inServerId);
            inUpdateWrapper.set(SmsTemplate::getServerCode, req.getInServerCode());
            inUpdateWrapper.set(SmsTemplate::getUpdateTime, new Date());
            inUpdateWrapper.set(SmsTemplate::getUpdateUser, UserThreadLocal.getUserId().toString());
            inUpdateWrapper.in(SmsTemplate::getTemplateId, inTemplateIds);

        }
        if (Objects.isNull(outServerId)
                || !outServerId.equals(oldOutServerId)) {
            // 国际发生变更 -- 将对应的国内模板至为无效状态，需重新审核
            smsTemplateList =
                    smsTemplateService.list(Wrappers.<SmsTemplate>lambdaQuery()
                            .eq(SmsTemplate::getClientId, clientId)
                            .eq(SmsTemplate::getCountryType, CountryTypeEnums.OUT.getCode()));
            outTemplateIds = smsTemplateList.stream().map(smsTemplate -> {
                return smsTemplate.getTemplateId();
            }).collect(Collectors.toList());

            outUpdateWrapper = new LambdaUpdateWrapper<>();
            outUpdateWrapper.set(SmsTemplate::getStatus, TemplateStatusEnums.WAIT_APPROVALED.getCode());
            outUpdateWrapper.set(SmsTemplate::getSignId, null);
            outUpdateWrapper.set(SmsTemplate::getSignName, null);
            outUpdateWrapper.set(SmsTemplate::getTemplateConvertContent, null);
            if (Objects.isNull(outServerId)) {
                outUpdateWrapper.set(SmsTemplate::getClientId, null);
            }
            outUpdateWrapper.set(SmsTemplate::getServerTemplateId, null);
            outUpdateWrapper.set(SmsTemplate::getServerId, outServerId);
            outUpdateWrapper.set(SmsTemplate::getServerCode, req.getOutServerCode());
            outUpdateWrapper.set(SmsTemplate::getUpdateTime, new Date());
            outUpdateWrapper.set(SmsTemplate::getUpdateUser, UserThreadLocal.getUserId().toString());
            outUpdateWrapper.in(SmsTemplate::getTemplateId, outTemplateIds);

        }

        LambdaUpdateWrapper<SmsClient> clientUpdateWrapper = new LambdaUpdateWrapper<>();
        clientUpdateWrapper.set(SmsClient::getRecordDays, req.getRecordDays());
        clientUpdateWrapper.set(SmsClient::getInThreshold, req.getInThreshold());
        clientUpdateWrapper.set(SmsClient::getOutThreshold, req.getOutThreshold());
        clientUpdateWrapper.set(SmsClient::getInServerId, req.getInServerId());
        clientUpdateWrapper.set(SmsClient::getOutServerId, req.getOutServerId());
        clientUpdateWrapper.set(SmsClient::getInServerCode, Objects.equals(req.getInServerId(), null)
                ? null : req.getInServerCode());
        clientUpdateWrapper.set(SmsClient::getOutServerCode, Objects.equals(req.getOutServerId(), null)
                ? null : req.getOutServerCode());
        clientUpdateWrapper.set(SmsClient::getThreshold, req.getThreshold());
        clientUpdateWrapper.set(SmsClient::getUpdateTime, new Date());
        clientUpdateWrapper.set(SmsClient::getUpdateUser, UserThreadLocal.getUserId().toString());
        clientUpdateWrapper.eq(SmsClient::getClientId, clientId);


        LambdaUpdateWrapper<SmsTemplate> finalInUpdateWrapper = inUpdateWrapper;
        LambdaUpdateWrapper<SmsTemplate> finalOutUpdateWrapper = outUpdateWrapper;
        LambdaUpdateWrapper<SmsClient> finalClientUpdateWrapper = clientUpdateWrapper;
        List<Long> finalInTemplateIds = inTemplateIds;
        List<Long> finalOutTemplateIds = outTemplateIds;
        transactionTemplate.executeWithoutResult(action -> {
            if (CollectionUtil.isNotEmpty(finalInTemplateIds)) {
                smsTemplateService.update(finalInUpdateWrapper);
            }
            if (CollectionUtil.isNotEmpty(finalOutTemplateIds)) {
                smsTemplateService.update(finalOutUpdateWrapper);
            }
            smsClientService.update(clientUpdateWrapper);
        });


        List<SmsTemplate> finalSmsTemplateList = smsTemplateList;

        executor.execute(() -> {
            if (finalSmsTemplateList.size() > 0) {

                Map<Long, String> serMap = smsServerMapper.selectList(Wrappers.<SmsServer>lambdaQuery()
                        .eq(SmsServer::getStatus, StatusEnums.NORMAL.getCode()))
                        .stream().collect(Collectors.toMap(SmsServer::getServerId, SmsServer::getServerCode));

                for (SmsTemplate item : finalSmsTemplateList) {

                    ISmsHandler handler = handleBean.getSmsHandler(serMap.get(item.getServerId()));
                    SmsTemplateInfo templateInfo = SmsTemplate.convertInfo(item, handler);

                    SmsRedisUtil.sendRedisQueue(templateTopic, templateInfo);
                    SmsRedisUtil.deletePut(SmsConstants.SMS_TEMPLATE
                            + ":" + item.getClientId(), SmsTemplateInfo.class, templateInfo);
                }
            }

            SmsClient item = smsClientMapper.selectById(clientId);
            // 推送客户端信息到redis
            SmsClientInfo smsClientInfo =
                    SmsClientApprovalServiceIpml.convertInfo(item, smsQuotaMapper);

            SmsRedisUtil.sendRedisQueue(clientTopic, smsClientInfo);
            SmsRedisUtil.updatePut(SmsConstants.SMS_CLIENT, SmsClientInfo.class, smsClientInfo);
        });
    }

    @Override
    public void rejected(SmsClientApprovalRejectedReq req) {
        SmsClient smsClient = req.entity();
        Long clientId = smsClient.getClientId();
        // 根据当前客户端状态判断是否需要审批
        SmsClient entity = smsClientMapper.selectById(clientId);
        if (!Objects.equals(ClientStatusEnums.IN_APPROVALED.getCode(), entity.getStatus())) {
            throw new GlobalException(TipsEnum.getTips(TipsEnum.STATUS_NOREFUSE));
        }
        smsClient.setStatus(ClientStatusEnums.NOT_APPROVALED.getCode());
        smsClient.setReviewer(UserThreadLocal.getUserId().toString());
        smsClient.setReviewerDate(new Date());
        smsClientMapper.updateById(smsClient);
    }

