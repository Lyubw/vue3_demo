                clientMailSendParams.setInitialSumQuota(inInitial);
                clientMailSendParams.setUseSumQuota(inUsable);
                clientMailSendParams.setType(CountryTypeEnums.IN.getCode());
                clientMailSendParams.setUserId(item.getApplicant());
                _sendItems.add(clientMailSendParams);
            }

            if (!(outQuotient.compareTo(threshold) < 0)) {

                ClientMailSendParams clientMailSendParams = new ClientMailSendParams();

                clientMailSendParams.setClientCode(item.getClientCode());
                clientMailSendParams.setClientName(item.getSystemName());
                clientMailSendParams.setAppName(item.getAppName());
                clientMailSendParams.setSmsProvider(SmsServerEnums.getNameByCode(item.getOutServerCode()));
